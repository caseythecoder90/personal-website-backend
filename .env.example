# ===========================================
# Production Environment Variables
# Copy this file to .env and fill in real values
# ===========================================

# PostgreSQL (used by postgres container)
POSTGRES_DB=casquinn_personal_website
POSTGRES_USER=casquinn
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# Spring Boot Database Connection
# Note: hostname "postgres" is the Docker Compose service name
DB_URL=jdbc:postgresql://postgres:5432/casquinn_personal_website
DB_USER=casquinn
DB_PASSWORD=CHANGE_ME_SAME_AS_POSTGRES_PASSWORD

# Redis
# Note: hostname "redis" is the Docker Compose service name
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# Cloudinary (image/resume storage)
CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# JWT Authentication
JWT_SECRET=CHANGE_ME_GENERATE_64_CHAR_HEX_STRING

# Jasypt Encryption
JASYPT_ENCRYPTOR_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Resend Email
RESEND_API_KEY=re_xxxxxxxxxxxx
OWNER_EMAIL=your-email@example.com
