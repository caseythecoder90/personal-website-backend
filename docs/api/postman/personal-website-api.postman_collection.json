{
	"info": {
		"_postman_id": "1eaf7fff-2bd2-4806-80f1-350d97093403",
		"name": "Personal Website API",
		"description": "Complete API collection for the Personal Website backend.\n\nSetup:\n1. Set `baseUrl` variable to your environment\n2. Run 'Login' request first to get a JWT token\n3. The token is auto-saved to the `token` variable\n4. All protected endpoints use Bearer auth from the `token` variable\n\nEndpoint groups: Auth, Operations, Projects, Project Links, Project Images, Technologies, Certifications, Blog (Posts, Categories, Tags, Images), Contact Submissions, Resume.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "43584912"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.data && jsonData.data.token) {",
									"        pm.collectionVariables.set('token', jsonData.data.token);",
									"        console.log('Token saved to collection variable');",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						},
						"description": "Authenticate and receive a JWT token. Token is automatically saved to the `token` collection variable for use in protected endpoints."
					},
					"response": []
				},
				{
					"name": "Login - Invalid Credentials",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"wrongpassword\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						},
						"description": "Test invalid credentials. Expected: 401 Unauthorized."
					},
					"response": []
				}
			],
			"description": "JWT authentication endpoints"
		},
